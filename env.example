# Copy this file to .env and fill in your values.
# Never commit .env to the repo.

# Set to true to run without real tool binaries (for local dev and demos)
TOOL_MOCK_MODE=true

# Ollama endpoint — use localhost if running Ollama on your own machine,
# or https://ollama.com/v1 to use Ollama Cloud (no local install needed).
OLLAMA_BASE_URL=https://ollama.com/v1

# Model to use. qwen3.5:cloud runs on Ollama's servers, not your machine —
# good for low-RAM VMs. Change if your mentor specifies another model.
OLLAMA_MODEL=gpt-oss:20b-cloud

# Get this from https://ollama.com/settings/keys (only needed for cloud;
# local Ollama ignores this value).
OLLAMA_API_KEY= #your_api_key

# Folder where script-based real tools (XSStrike, smuggler, SSRFmap, SSTImap)
# get git-cloned into. Binary tools (httpx-toolkit, sqlmap, dalfox, crlfuzz)
# are expected to already be on PATH — see README's "Installing the real
# tools" section. Not needed while TOOL_MOCK_MODE=true.
TOOLS_DIR=~/tools
